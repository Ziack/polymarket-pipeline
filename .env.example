# Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-...

# Polymarket CLOB API (optional — for live trading)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=

# Twitter API v2 (optional — real-time news stream)
TWITTER_BEARER_TOKEN=

# Telegram — Telethon user account (reads any public channel, no admin needed)
# Get api_id + api_hash from https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_CHANNEL_IDS=

# NewsAPI.org (optional — broader news coverage)
NEWSAPI_KEY=

# Pipeline Settings
DRY_RUN=true
MAX_BET_USD=25
DAILY_LOSS_LIMIT_USD=100
EDGE_THRESHOLD=0.05

# V2 Settings
MAX_VOLUME_USD=500000
MIN_VOLUME_USD=1000
MATERIALITY_THRESHOLD=0.45
SPEED_TARGET_SECONDS=5
